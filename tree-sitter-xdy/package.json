{
  "name": "tree-sitter-xdy",
  "version": "0.1.0",
  "description": "tree-sitter grammar for xDy dice expression language.",
  "readme": "README.md",
  "scripts": {
    "build": "tree-sitter generate && tree-sitter build",
    "test": "tree-sitter test && cargo test",
    "install": "node-gyp-build",
    "prebuildify": "prebuildify --napi --strip"
  },
  "keywords": [
    "xdy",
    "dice",
    "rpg"
  ],
  "files": [
    "grammar.js",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**"
  ],
  "author": "Todd L Smith <todd@availlang.org>",
  "license": "BSD-3-Clause",
  "dependencies": {
    "node-addon-api": "^8.8.0",
    "node-gyp-build": "^4.8.0"
  },
  "peerDependencies": {
    "tree-sitter": "^0.25.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "devDependencies": {
    "prebuildify": "^6.0.0",
    "tree-sitter-cli": "^0.26.9"
  },
  "types": "bindings/node"
}
